{
  "Date and Time": {
    "prefix": "datetime",
    "body": [
      "${CURRENT_DATE}/${CURRENT_MONTH}-${CURRENT_YEAR} ${CURRENT_HOUR}:${CURRENT_MINUTE}:${CURRENT_SECOND}"
    ],
    "description": "Date time stamp"
  },
  "TODO comment": {
    "prefix": "todo",
    "body": ["${LINE_COMMENT} TODO", "${LINE_COMMENT} ${1}"],
    "description": "Adds a comment with a todo header"
  },
  "Shebang": {
    "prefix": "shebang",
    "body": ["#!/usr/bin/env ${1:${TM_FILENAME}}"],
    "description": "Adds a shebang"
  },
  "test": {
    "prefix": "test",
    "body": ["test"],
    "description": "test"
  }
}
